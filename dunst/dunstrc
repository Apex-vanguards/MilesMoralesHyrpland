[global]
    icon_theme = Papirus-Dark
    transparency = 20
    monitor = 0
    follow = mouse
    width = 340
    height = (0, 300)
    origin = top-right
    offset = (15, 45)
    notification_limit = 5
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 10
    frame_width = 2
    gap_size = 8
    separator_height = 0
    sort = yes
    idle_threshold = 120
    font = JetBrainsMono Nerd Font 12
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    word_wrap = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    enable_recursive_icon_lookup = true
    sticky_history = yes
    history_length = 20
    always_run_script = true
    corner_radius = 10 
    # Global cerceve ve arxa plani tund goy etdik
    frame_color = "#004488"
    background = "#00050a"
    foreground = "#d1dce8"

[urgency_low]
    # Hafif bildirimler: Tund lacivert
    background = "#00050a"
    foreground = "#6688aa"
    frame_color = "#002244"
    timeout = 3

[urgency_normal]
    # Normal bildirimler: Cyberpunk Mavi
    background = "#001122"
    foreground = "#e0e8f0"
    frame_color = "#007acc"
    timeout = 6

[urgency_critical]
    # Acil bildirimler: Neon Mavi (Cyberpunk Alert)
    background = "#002244" 
    foreground = "#ffffff"
    frame_color = "#00ffff"
    timeout = 0
