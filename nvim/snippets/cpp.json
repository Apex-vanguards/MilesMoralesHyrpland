  "lazy_tree": {
    "prefix": "lazy_tree",
    "body": [
      "const int MAXN = 3e6 + 5;",
      "int lazy[MAXN * 4], tree[MAXN * 4], arr[MAXN];",
      "",
      "void build(int tl, int tr, int node) {",
      "  if (tl == tr) {",
      "    tree[node] = arr[tl];",
      "    return;",
      "  }",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  build(tl, tm, node * 2);",
      "  build(tm + 1, tr, node * 2 + 1);",
      "",
      "  tree[node] = tree[node * 2] + tree[node * 2 + 1];",
      "}",
      "",
      "void relax(int tl, int tr, int node) {",
      "  if (lazy[node] != 0) {",
      "    tree[node] = lazy[node] * (tr - tl + 1);",
      "",
      "    if (tl != tr) {",
      "      lazy[node * 2] = lazy[node];",
      "      lazy[node * 2 + 1] = lazy[node];",
      "    }",
      "",
      "    lazy[node] = 0;",
      "  }",
      "}",
      "",
      "void update(int tl, int tr, int l, int r, int val, int node) {",
      "  relax(tl, tr, node);",
      "",
      "  if (l > r)",
      "    return;",
      "",
      "  if (tl > r || tr < l)",
      "    return;",
      "",
      "  if (l <= tl && tr <= r) {",
      "    lazy[node] = val;",
      "    relax(tl, tr, node);",
      "    return;",
      "  }",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  update(tl, tm, l, r, val, node * 2);",
      "  update(tm + 1, tr, l, r, val, node * 2 + 1);",
      "",
      "  tree[node] = tree[node * 2] + tree[node * 2 + 1];",
      "}",
      "",
      "int get(int tl, int tr, int l, int r, int node) {",
      "  relax(tl, tr, node);",
      "",
      "  if (l > r)",
      "    return 0;",
      "",
      "  if (tl > r || tr < l)",
      "    return 0;",
      "",
      "  if (l <= tl && tr <= r) ",
      "    return tree[node];",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  int sum_left = get(tl, tm, l, r, node * 2);",
      "  int sum_right = get(tm + 1, tr, l, r, node * 2 + 1);",
      "",
      "  return sum_right + sum_left;",
      "}",
      "$0"
    ],
    "description": "Segment Tree with Lazy Propagation (Range Update & Range Sum)"
  },
  "seg_tree": {
    "prefix": "seg_tree",
    "body": [
      "const int MAXN = 3e6 + 5;",
      "int tree[MAXN * 4], arr[MAXN];",
      "",
      "void build(int tl, int tr, int node) {",
      "  if (tl == tr) {",
      "    tree[node] = arr[tl];",
      "    return;",
      "  }",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  build(tl, tm, node * 2);",
      "  build(tm + 1, tr, node * 2 + 1);",
      "",
      "  tree[node] = tree[node * 2] + tree[node * 2 + 1];",
      "}",
      "",
      "void update(int tl, int tr, int idx, int val, int node) {",
      "  if (tl == tr) {",
      "    tree[node] = val;",
      "    return;",
      "  }",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  if (idx <= tm)",
      "    update(tl, tm, idx, val, node * 2);",
      "  else",
      "    update(tm + 1, tr, idx, val, node * 2 + 1);",
      "",
      "  tree[node] = tree[node * 2] + tree[node * 2 + 1];",
      "}",
      "",
      "int get(int tl, int tr, int l, int r, int node) {",
      "  if (l > r)",
      "    return 0;",
      "",
      "  if (tl > r || tr < l)",
      "    return 0;",
      "",
      "  if (l <= tl && tr <= r)",
      "    return tree[node];",
      "",
      "  int tm = (tl + tr) >> 1LL;",
      "",
      "  int left_sum = get(tl, tm, l, r, node * 2);",
      "  int right_sum = get(tm + 1, tr, l, r, node * 2 + 1);",
      "",
      "  return left_sum + right_sum;",
      "}",
      "$0"
    ],
    "description": "Standard Segment Tree (Point Update & Range Sum) Original"
  },
  "fenwick_tree": {
    "prefix": "fenwick_tree",
    "body": [
      "struct BIT {",
      "    vector<int> ft;",
      "    int n;",
      "    BIT(int N) {",
      "        n = N + 10;",
      "        ft.assign(n + 5, 0);",
      "    }",
      "",
      "    void add(int idx, int val) {",
      "        for (idx; idx <= n; idx += (idx & (-idx))) {",
      "            ft[idx] += val;",
      "        }",
      "    }",
      "",
      "    int get(int idx) {",
      "        int ret = 0;",
      "",
      "        for (idx; idx > 0; idx -= (idx & (-idx))) {",
      "            ret += ft[idx];",
      "        }",
      "        return ret;",
      "    }",
      "};",
      "$0"
    ],
    "description": "Fenwick Tree (Binary Indexed Tree) Structure"
  },
  "dsu": {
    "prefix": "dsu",
    "body": [
      "struct DSU {",
      "    vector<int> parent, size;",
      "    DSU(int n) {",
      "        parent.resize(n + 5);",
      "        size.assign(n + 5, 1);",
      "        for (int i = 0; i <= n; i++) parent[i] = i;",
      "    }",
      "    int find_set(int v) {",
      "        if (v == parent[v]) return v;",
      "        return parent[v] = find_set(parent[v]);",
      "    }",
      "    void union_sets(int a, int b) {",
      "        a = find_set(a);",
      "        b = find_set(b);",
      "        if (a != b) {",
      "            if (size[a] < size[b]) swap(a, b);",
      "            parent[b] = a;",
      "            size[a] += size[b];",
      "        }",
      "    }",
      "};",
      "$0"
    ],
    "description": "Disjoint Set Union (Union Find) Structure"
  },
  "binpow": {
    "prefix": "binpow",
    "body": [
      "int binpow(int a, int b, int m) {",
      "    a %= m;",
      "    int res = 1;",
      "    while (b > 0) {",
      "        if (b & 1) res = res * a % m;",
      "        a = a * a % m;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}",
      "",
      "int modInverse(int n, int m) {",
      "    return binpow(n, m - 2, m);",
      "}",
      "$0"
    ],
    "description": "Binary Exponentiation and Modular Inverse"
  },
  "sieve": {
    "prefix": "sieve",
    "body": [
      "const int PRIME_MAX = 1e6 + 5;",
      "vector<bool> is_prime(PRIME_MAX, true);",
      "vector<int> primes;",
      "",
      "void sieve() {",
      "    is_prime[0] = is_prime[1] = false;",
      "    for (int i = 2; i * i < PRIME_MAX; i++) {",
      "        if (is_prime[i]) {",
      "            for (int j = i * i; j < PRIME_MAX; j += i)",
      "                is_prime[j] = false;",
      "        }",
      "    }",
      "    for (int i = 2; i < PRIME_MAX; i++) {",
      "        if (is_prime[i]) primes.push_back(i);",
      "    }",
      "}",
      "$0"
    ],
    "description": "Sieve of Eratosthenes for prime generation"
  },
  "mint": {
    "prefix": "mint",
    "body": [
      "template<int mod>",
      "struct Modular {",
      "  int v;",
      "  Modular(int _v = 0) {",
      "    v = _v % mod;",
      "    if (v < 0) v += mod;",
      "  }",
      "  Modular& operator += (const Modular& o) {",
      "    v += o.v;",
      "    if (v >= mod) v -= mod;",
      "    return *this;",
      "  }",
      "  Modular& operator -= (const Modular& o) {",
      "    v -= o.v;",
      "    if (v < 0) v += mod;",
      "    return *this;",
      "  }",
      "  Modular& operator *= (const Modular& o) {",
      "    v = 1LL * v * o.v % mod;",
      "    v %= mod;",
      "    return *this;",
      "  }",
      "  friend Modular operator + (Modular a, const Modular& b) { return a += b; }",
      "  friend Modular operator - (Modular a, const Modular& b) { return a -= b; }",
      "  friend Modular operator * (Modular a, const Modular& b) { return a *= b; }",
      "  Modular power(int b) const {",
      "    Modular ans = 1, a = *this;",
      "    while (b > 0) {",
      "      if (b & 1) ans *= a;",
      "      a *= a;",
      "      b >>= 1;",
      "    }",
      "    return ans;",
      "  }",
      "  Modular inverse() const { return power(mod - 2); }",
      "  Modular& operator /= (const Modular& o) { return *this *= o.inverse(); }",
      "  friend Modular operator / (Modular a, const Modular& b) { return a /= b; }",
      "  friend ostream& operator << (ostream& os, const Modular& m) { return os << m.v; }",
      "  friend istream& operator >> (istream& is, Modular& m) {",
      "    int x; is >> x;",
      "    m = Modular(x); return is;",
      "  }",
      "};",
      "",
      "using Mint = Modular<1000000007>;",
      "$0"
    ],
    "description": "Modular Arithmetic Struct (Mint) for Competitive Programming"
  }
}
