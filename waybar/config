{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 0,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "custom/spider",
        "hyprland/workspaces",
        "custom/separator",
        "hyprland/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "mpris",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "network",
        "custom/separator",
        "cpu",
        "memory",
        "custom/separator",
        "temperature",
        "custom/separator",
        "battery",
        "custom/separator",
        "tray"
    ],

    // ─── LEFT ────────────────────────────────────────────────────────────────

    "custom/spider": {
        "format": "",
        "tooltip": false,
        "on-click": "wlogout --protocol layer-shell -b 5 -T 400 -B 400",
        "interval": "once"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "①",
            "2": "②",
            "3": "③",
            "4": "④",
            "5": "⑤",
            "6": "⑥",
            "7": "⑦",
            "8": "⑧",
            "9": "⑨",
            "urgent": "",
            "active": "",
            "default": ""
        },
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },

    "hyprland/window": {
        "format": "  {title}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) — Mozilla Firefox": "🌐 $1",
            "(.*) - fish": " $1",
            "": " Desktop"
        }
    },

    // ─── CENTER ───────────────────────────────────────────────────────────────

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%a %d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ff2020'><b>{}</b></span>",
                "days": "<span color='#e0e0e0'>{}</span>",
                "weekdays": "<span color='#ff2020'><b>{}</b></span>",
                "today": "<span color='#ff2020'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    // ─── RIGHT ────────────────────────────────────────────────────────────────

    "mpris": {
        "format": "{player_icon}  {dynamic}",
        "format-paused": "{status_icon}  <i>{dynamic}</i>",
        "format-stopped": "",
        "dynamic-len": 28,
        "dynamic-order": ["title", "artist"],
        "player-icons": {
            "default": "▶",
            "mpv": "🎬",
            "spotify": "",
            "firefox": "󰈹",
            "chromium": ""
        },
        "status-icons": {
            "paused": ""
        },
        "ignored-players": ["firefox"]
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "󰝟  muted",
        "format-bluetooth": "󰂯  {volume}%",
        "format-bluetooth-muted": "󰂲  muted",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋎",
            "headset": "󰋎",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip": true,
        "tooltip-format": "{desc}"
    },

    "network": {
        "format-wifi": "󰤨  {essid}",
        "format-ethernet": "󰈀  {ifname}",
        "format-disconnected": "󰤭  offline",
        "format-linked": "󰈀  {ifname}",
        "tooltip-format": "󰤨 {essid}\n󰩟 {ipaddr}/{cidr}\n󰕒 {bandwidthUpBytes}  󰇚 {bandwidthDownBytes}",
        "tooltip-format-wifi": "󰤨 {essid} ({signalStrength}%)\n󰩟 {ipaddr}/{cidr}\n󰕒 {bandwidthUpBytes}  󰇚 {bandwidthDownBytes}",
        "tooltip-format-ethernet": "󰈀 {ifname}\n󰩟 {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 5,
        "on-click": "nm-connection-editor"
    },

    "cpu": {
        "format": "  {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "interval": 3,
        "on-click": "kitty --class htop -e htop"
    },

    "memory": {
        "format": "  {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "Used: {used:0.2f} GB / {total:0.2f} GB\nAvail: {avail:0.2f} GB",
        "interval": 5,
        "on-click": "kitty --class htop -e htop"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon}  {temperatureC}°C",
        "format-critical": "  {temperatureC}°C",
        "format-icons": ["", "", "", "", ""],
        "tooltip": false
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "󰂄  {capacity}%",
        "format-plugged": "󰚥  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["󰂃", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format": "{timeTo}\nPower: {power}W"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true
    },

    "custom/separator": {
        "format": "│",
        "interval": "once",
        "tooltip": false
    }
}
